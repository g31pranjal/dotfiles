#!/usr/bin/env python3
"""delete-claude-sessions - Delete Claude Code session transcripts.

Usage:
  delete-claude-sessions -i <session-id>   Delete one session's transcript
  delete-claude-sessions -c <cwd>          Delete the entire session folder
                                           for that working directory

Pass -f/--force to skip the confirmation prompt.
"""

import argparse
import shutil
import sys
from pathlib import Path

PROJECTS_DIR = Path.home() / ".claude" / "projects"


def encode_cwd(cwd):
    """Same encoding Claude Code uses for ~/.claude/projects/<dir>: / and _ -> -."""
    return cwd.replace("/", "-").replace("_", "-")


def normalize_cwd(s):
    p = Path(s).expanduser()
    if not p.is_absolute():
        p = Path.cwd() / p
    s = str(p).rstrip("/")
    return s or "/"


def confirm(prompt):
    try:
        ans = input(f"{prompt} [y/N] ").strip().lower()
    except (KeyboardInterrupt, EOFError):
        print()
        return False
    return ans in ("y", "yes")


def die(msg):
    print(f"Error: {msg}", file=sys.stderr)
    sys.exit(1)


def delete_session_id(sid, force):
    matches = list(PROJECTS_DIR.glob(f"*/{sid}.jsonl"))
    if not matches:
        die(f"no session found with id: {sid}")
    rc = 0
    for path in matches:
        if not force and not confirm(f"Delete {path}?"):
            print(f"Skipped {path}")
            continue
        try:
            path.unlink()
            print(f"Deleted {path}")
        except OSError as e:
            print(f"Failed to delete {path}: {e}", file=sys.stderr)
            rc = 1
    return rc


def delete_cwd(cwd_input, force):
    cwd = normalize_cwd(cwd_input)
    folder = PROJECTS_DIR / encode_cwd(cwd)
    if not folder.is_dir():
        die(f"no session folder for cwd: {cwd}\n  (looked for: {folder})")
    count = len(list(folder.glob("*.jsonl")))
    if count == 0:
        die(f"no sessions in folder: {folder}")
    if not force and not confirm(f"Delete {count} session(s) at {folder}?"):
        print("Cancelled.")
        return 0
    try:
        shutil.rmtree(folder)
    except OSError as e:
        die(f"failed to delete {folder}: {e}")
    print(f"Deleted {folder} ({count} session(s))")
    return 0


def main():
    ap = argparse.ArgumentParser(
        description="Delete Claude Code session transcripts.",
    )
    target = ap.add_mutually_exclusive_group(required=True)
    target.add_argument("-i", "--id", dest="session_id", metavar="UUID",
                        help="Delete the transcript for this session ID")
    target.add_argument("-c", "--cwd", dest="cwd", metavar="PATH",
                        help="Delete the entire session folder for this cwd")
    ap.add_argument("-f", "--force", action="store_true", help="Skip confirmation")
    args = ap.parse_args()

    if args.session_id:
        return delete_session_id(args.session_id, args.force)
    return delete_cwd(args.cwd, args.force)


if __name__ == "__main__":
    sys.exit(main() or 0)
