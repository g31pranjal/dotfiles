#!/usr/bin/env python3
"""list-claude-sessions - List all Claude Code sessions across projects.

Walks ~/.claude/projects/ and prints one row per session, most recent first.

Markers in the TITLE / PREVIEW column:
  *   session has a custom title (set via `claude --name <title>`)
  ↻   resumed session (--continue or --resume); preview is the first
      *real* user prompt, skipping past the synthetic replay records

The PID column shows the live process ID for sessions currently running
(determined by checking ~/.claude/sessions/<pid>.json for an existing process);
blank for sessions that aren't active.
"""

import json
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path

PROJECTS_DIR = Path.home() / ".claude" / "projects"
SESSIONS_DIR = Path.home() / ".claude" / "sessions"

# User records whose content starts with one of these are synthetic
# (slash-command artifacts and resume-replay scaffolding), not typed input.
SYNTHETIC_PREFIXES = (
    "<local-command-caveat>",
    "<local-command-stdout>",
    "<local-command-stderr>",
    "<command-name>",
    "<command-message>",
    "<command-args>",
)


def user_text(rec):
    content = rec.get("message", {}).get("content")
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        for part in content:
            if isinstance(part, dict) and part.get("type") == "text":
                return part.get("text", "")
    return ""


def is_synthetic_user(rec):
    if rec.get("isMeta"):
        return True
    return user_text(rec).lstrip().startswith(SYNTHETIC_PREFIXES)


def session_summary(jsonl_path):
    cwd = None
    custom_title = None
    first_msg = None
    msg_count = 0
    last_ts = None
    resumed = None  # True if first user record was synthetic; False once we see a real one

    with jsonl_path.open() as fh:
        for line in fh:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                continue

            rec_type = rec.get("type")

            if rec_type == "custom-title":
                custom_title = rec.get("customTitle")
                continue

            if rec_type in ("user", "assistant"):
                msg_count += 1
                ts = rec.get("timestamp")
                if ts:
                    last_ts = ts

            if rec_type == "user":
                if cwd is None:
                    cwd = rec.get("cwd")
                if first_msg is None:
                    synthetic = is_synthetic_user(rec)
                    if resumed is None:
                        resumed = synthetic
                    if not synthetic:
                        first_msg = user_text(rec)

    return {
        "session_id": jsonl_path.stem,
        "cwd": cwd,
        "title": custom_title,
        "first_msg": first_msg or "",
        "msg_count": msg_count,
        "last_ts": last_ts,
        "mtime": jsonl_path.stat().st_mtime,
        "resumed": bool(resumed),
    }


def fmt_time(iso_ts, mtime):
    if iso_ts:
        try:
            dt = datetime.fromisoformat(iso_ts.replace("Z", "+00:00"))
            return dt.astimezone().strftime("%Y-%m-%d %H:%M")
        except ValueError:
            pass
    return datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M")


def truncate(s, n):
    s = s.replace("\n", " ").replace("\r", " ")
    return s if len(s) <= n else s[: n - 1] + "…"


def shorten_cwd(cwd):
    if not cwd:
        return ""
    home = str(Path.home())
    return cwd.replace(home, "~", 1) if cwd.startswith(home) else cwd


def process_command(pid):
    """Return the full command string of a running PID, or None if not running."""
    try:
        out = subprocess.run(
            ["ps", "-p", str(pid), "-o", "args="],
            capture_output=True, text=True, timeout=2,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if out.returncode != 0:
        return None
    cmd = out.stdout.strip()
    return cmd or None


def pids_by_session():
    """Return (active, dead) where each maps sessionId -> list of dicts
    {pid, cwd, started_ms}. Active = process exists and looks like claude.
    Dead = process is gone, or PID was recycled by something non-claude.
    """
    active = {}
    dead = {}
    if not SESSIONS_DIR.is_dir():
        return active, dead
    for f in SESSIONS_DIR.glob("*.json"):
        try:
            data = json.loads(f.read_text())
        except (OSError, json.JSONDecodeError):
            continue
        pid = data.get("pid")
        sid = data.get("sessionId")
        if not isinstance(pid, int) or not sid:
            continue

        entry = {"pid": pid, "cwd": data.get("cwd"), "started_ms": data.get("startedAt")}

        try:
            os.kill(pid, 0)
            exists, owned = True, True
        except ProcessLookupError:
            exists, owned = False, False
        except PermissionError:
            exists, owned = True, False

        if not exists:
            dead.setdefault(sid, []).append(entry)
            continue

        if not owned:
            active.setdefault(sid, []).append(entry)
            continue

        cmd = process_command(pid)
        if cmd is None or "claude" not in cmd.lower():
            dead.setdefault(sid, []).append(entry)
            continue

        active.setdefault(sid, []).append(entry)

    # Sort each list by pid for stable display.
    for d in (active, dead):
        for sid in d:
            d[sid].sort(key=lambda e: e["pid"])

    return active, dead


def main():
    if not PROJECTS_DIR.is_dir():
        print(f"No such directory: {PROJECTS_DIR}", file=sys.stderr)
        sys.exit(1)

    rows = [session_summary(p) for p in PROJECTS_DIR.glob("*/*.jsonl")]

    active, dead = pids_by_session()

    # Add synthetic rows for live sessions that don't yet have a transcript.
    seen_ids = {r["session_id"] for r in rows}
    for sid, entries in active.items():
        if sid in seen_ids:
            continue
        # Use the earliest startedAt among the entries for the row's timestamp.
        starts = [e["started_ms"] for e in entries if isinstance(e.get("started_ms"), (int, float))]
        ts_iso = None
        if starts:
            ts_iso = datetime.fromtimestamp(min(starts) / 1000).isoformat() + "Z"
        rows.append({
            "session_id": sid,
            "cwd": entries[0].get("cwd"),
            "title": None,
            "first_msg": "(no transcript)",
            "msg_count": 0,
            "last_ts": ts_iso,
            "mtime": 0,
            "resumed": False,
            "no_transcript": True,
        })

    # Stable sort: time desc within each cwd group, cwd asc.
    rows.sort(key=lambda r: r["last_ts"] or "", reverse=True)
    rows.sort(key=lambda r: r["cwd"] or "")

    if not rows:
        print("No sessions found.")
        return

    def pids_for(sid):
        if sid in active:
            return [str(e["pid"]) for e in active[sid]]
        if sid in dead:
            return [str(e["pid"]) for e in dead[sid]]
        return []

    sid_w = max(len(r["session_id"]) for r in rows)
    cwd_w = max(len(r["cwd"] or "") for r in rows)
    pid_w = max(
        (max((len(p) for p in pids_for(r["session_id"])), default=0) for r in rows),
        default=0,
    )
    pid_w = max(pid_w, len("PID"))

    use_color = sys.stdout.isatty()
    RED = "\033[31m" if use_color else ""
    GREEN = "\033[32m" if use_color else ""
    GREY = "\033[90m" if use_color else ""
    RESET = "\033[0m" if use_color else ""

    header = (
        f"{'TIME':<16}  {'SESSION':<{sid_w}}  {'PID':<{pid_w}}  "
        f"{'MSGS':>4}  {'CWD':<{cwd_w}}  TITLE / PREVIEW"
    )
    print(header)
    print("-" * len(header))
    blank_time = " " * 16
    blank_sid = " " * sid_w
    blank_msgs = " " * 4
    blank_cwd_template = " " * cwd_w
    for r in rows:
        time_str = fmt_time(r["last_ts"], r["mtime"])
        cwd = r["cwd"] or ""
        label = r["title"] or r["first_msg"]
        markers = ("↻" if r["resumed"] else " ") + ("*" if r["title"] else " ")
        preview = truncate(label, 70)
        sid = r["session_id"]
        pids = pids_for(sid)

        if r.get("no_transcript"):
            color, reset = RED, RESET
        elif sid in active:
            color, reset = GREEN, RESET
        elif sid in dead:
            color, reset = GREY, RESET
        else:
            color, reset = "", ""

        first_pid = pids[0] if pids else ""
        print(
            f"{color}{time_str:<16}  {sid:<{sid_w}}  {first_pid:<{pid_w}}  "
            f"{r['msg_count']:>4}  {cwd:<{cwd_w}}  {markers} {preview}{reset}"
        )
        for extra_pid in pids[1:]:
            print(
                f"{color}{blank_time}  {blank_sid}  {extra_pid:<{pid_w}}  "
                f"{blank_msgs}  {blank_cwd_template}{reset}"
            )


if __name__ == "__main__":
    main()
