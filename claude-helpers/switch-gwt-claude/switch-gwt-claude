#!/bin/zsh
# switch-gwt-claude - Interactive worktree selector with Claude session resume
# Source this file or use it as a zsh plugin function.
# Usage: switch-gwt-claude

switch-gwt-claude() {
  # Check we're in a git repo
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: not inside a git repository"
    return 1
  fi

  # Get list of worktrees
  local -a worktree_paths
  local -a worktree_labels
  local -a worktree_branches
  local main_worktree
  main_worktree=$(git worktree list --porcelain | head -1 | sed 's/^worktree //')

  local wt_path branch
  while IFS= read -r line; do
    wt_path="${line%% *}"
    # Extract branch from brackets: [...branch...]
    branch="${line##*\[}"
    branch="${branch%%\]*}"

    if [[ "$wt_path" == "$main_worktree" ]]; then
      worktree_labels+=("$branch (main) - $wt_path")
    else
      worktree_labels+=("$branch - $wt_path")
    fi
    worktree_paths+=("$wt_path")
    worktree_branches+=("$branch")
  done < <(git worktree list)

  if [[ ${#worktree_paths[@]} -eq 0 ]]; then
    echo "No worktrees found."
    return 1
  fi

  local selected=1
  local total=${#worktree_labels[@]}

  # Save cursor, hide it, set up cleanup
  tput civis
  trap 'tput cnorm; trap - INT TERM; return 130' INT TERM

  _render() {
    local i
    # Clear previous render: move up and clear each line
    if [[ $1 == "redraw" ]]; then
      # Move up total+1 lines (header + items)
      printf '\e[%dA' "$((total + 1))"
    fi

    # Header
    printf '\e[2K\e[1mSelect a worktree (j/k/arrows, enter to select, q to quit):\e[0m\n'

    # Items
    for i in {1..$total}; do
      printf '\e[2K'  # clear line
      if [[ $i -eq $selected ]]; then
        printf '  \e[7m> %s\e[0m\n' "${worktree_labels[$i]}"
      else
        printf '    %s\n' "${worktree_labels[$i]}"
      fi
    done
  }

  _render "first"

  # Input loop
  while true; do
    local key=""
    read -rsk1 key

    case "$key" in
      $'\e')
        read -rsk1 -t 0.1 key
        if [[ "$key" == "[" ]]; then
          read -rsk1 -t 0.1 key
          case "$key" in
            A) ((selected > 1)) && ((selected--)) || selected=$total ;;
            B) ((selected < total)) && ((selected++)) || selected=1 ;;
          esac
        else
          # Bare escape - cancel
          tput cnorm
          printf '\n'
          echo "Cancelled."
          return 0
        fi
        ;;
      $'\n'|"")
        break
        ;;
      k)
        ((selected > 1)) && ((selected--)) || selected=$total
        ;;
      j)
        ((selected < total)) && ((selected++)) || selected=1
        ;;
      q)
        tput cnorm
        printf '\n'
        echo "Cancelled."
        return 0
        ;;
      *)
        continue
        ;;
    esac

    _render "redraw"
  done

  tput cnorm
  printf '\n'

  local chosen_path="${worktree_paths[$selected]}"
  local chosen_branch="${worktree_branches[$selected]}"
  echo "Switching to: $chosen_path"

  # cd to the selected worktree
  cd "$chosen_path" || return 1

  claude-sessions open
}

# If script is executed directly (not sourced), run the function
if [[ "$ZSH_EVAL_CONTEXT" != *:file* ]]; then
  switch-gwt-claude
fi
