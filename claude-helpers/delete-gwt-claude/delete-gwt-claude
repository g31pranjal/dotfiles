#!/bin/zsh
# delete-gwt-claude - Interactive worktree selector for deletion
# Usage: delete-gwt-claude

delete-gwt-claude() {
  # Check we're in a git repo
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: not inside a git repository"
    return 1
  fi

  local main_worktree
  main_worktree=$(git worktree list --porcelain | head -1 | sed 's/^worktree //')

  # If we're inside a non-main worktree, delete it directly
  local current_worktree
  current_worktree=$(git rev-parse --show-toplevel)

  if [[ "$current_worktree" != "$main_worktree" ]]; then
    local current_branch
    current_branch=$(git branch --show-current)

    printf "Delete current worktree '%s'? [y/N] " "$current_branch"
    read -rk1 confirm
    printf '\n'

    if [[ "$confirm" != [yY] ]]; then
      echo "Cancelled."
      return 0
    fi

    cd "$main_worktree" || cd ~
    git worktree remove "$current_worktree" --force
    _delete_session_folder "$current_worktree"
    echo "Deleted worktree '$current_branch'."
    return 0
  fi

  # Otherwise, show interactive picker for non-main worktrees
  local -a worktree_paths
  local -a worktree_labels
  local -a worktree_branches

  local wt_path branch
  while IFS= read -r line; do
    wt_path="${line%% *}"
    branch="${line##*\[}"
    branch="${branch%%\]*}"

    # Skip the main worktree
    if [[ "$wt_path" == "$main_worktree" ]]; then
      continue
    fi

    worktree_labels+=("$branch - $wt_path")
    worktree_paths+=("$wt_path")
    worktree_branches+=("$branch")
  done < <(git worktree list)

  if [[ ${#worktree_paths[@]} -eq 0 ]]; then
    echo "No worktrees to delete (only main exists)."
    return 1
  fi

  local selected=1
  local total=${#worktree_labels[@]}

  tput civis
  trap 'tput cnorm; trap - INT TERM; return 130' INT TERM

  _render() {
    local i
    if [[ $1 == "redraw" ]]; then
      printf '\e[%dA' "$((total + 1))"
    fi

    printf '\e[2K\e[1mSelect a worktree to delete (j/k/arrows, enter to select, q to quit):\e[0m\n'

    for i in {1..$total}; do
      printf '\e[2K'
      if [[ $i -eq $selected ]]; then
        printf '  \e[7m> %s\e[0m\n' "${worktree_labels[$i]}"
      else
        printf '    %s\n' "${worktree_labels[$i]}"
      fi
    done
  }

  _render "first"

  while true; do
    local key=""
    read -rsk1 key

    case "$key" in
      $'\e')
        read -rsk1 -t 0.1 key
        if [[ "$key" == "[" ]]; then
          read -rsk1 -t 0.1 key
          case "$key" in
            A) ((selected > 1)) && ((selected--)) || selected=$total ;;
            B) ((selected < total)) && ((selected++)) || selected=1 ;;
          esac
        else
          tput cnorm
          printf '\n'
          echo "Cancelled."
          return 0
        fi
        ;;
      $'\n'|"")
        break
        ;;
      k)
        ((selected > 1)) && ((selected--)) || selected=$total
        ;;
      j)
        ((selected < total)) && ((selected++)) || selected=1
        ;;
      q)
        tput cnorm
        printf '\n'
        echo "Cancelled."
        return 0
        ;;
      *)
        continue
        ;;
    esac

    _render "redraw"
  done

  tput cnorm
  printf '\n'

  local chosen_path="${worktree_paths[$selected]}"
  local chosen_branch="${worktree_branches[$selected]}"

  # Confirm deletion
  printf "Delete worktree at %s? [y/N] " "$chosen_path"
  read -rk1 confirm
  printf '\n'

  if [[ "$confirm" != [yY] ]]; then
    echo "Cancelled."
    return 0
  fi

  # Remove worktree
  git worktree remove "$chosen_path" --force
  _delete_session_folder "$chosen_path"

  echo "Deleted worktree '$chosen_branch'."
}

# Encode a cwd into the directory name Claude Code uses under
# ~/.claude/projects/ (slashes and underscores both become dashes), and
# remove that directory if present.
_delete_session_folder() {
  local cwd="$1"
  local encoded="${cwd//\//-}"
  encoded="${encoded//_/-}"
  local sessions_dir="$HOME/.claude/projects/$encoded"

  if [[ -d "$sessions_dir" ]]; then
    local count
    count=$(find "$sessions_dir" -maxdepth 1 -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')
    rm -rf "$sessions_dir"
    echo "Removed $count Claude session(s) at $sessions_dir"
  fi
}

# If script is executed directly (not sourced), run the function
if [[ "$ZSH_EVAL_CONTEXT" != *:file* ]]; then
  delete-gwt-claude
fi
