#!/bin/zsh
# new-gwt-claude - Create a git worktree and start Claude in the current tab
# Source this file or use it as a zsh plugin function.
# Usage: new-gwt-claude <branch_name>

new-gwt-claude() {
  if [[ -z "$1" ]]; then
    echo "Usage: new-gwt-claude <branch_name>"
    return 1
  fi

  local branch_name="$1"

  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: not inside a git repository"
    return 1
  fi

  local current_branch
  current_branch=$(git branch --show-current)
  if [[ "$current_branch" != "main" ]]; then
    echo "Error: not on main (currently on '$current_branch')"
    return 1
  fi

  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    echo "Error: branch '$branch_name' already exists"
    return 1
  fi

  if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "Error: working tree is not clean (staged or unstaged changes exist)"
    return 1
  fi

  local dir_name worktree_dir worktree_path
  dir_name=$(basename "$PWD")
  worktree_dir="../${dir_name}-worktrees"
  worktree_path="${worktree_dir}/${branch_name}"

  if [[ ! -d "$worktree_dir" ]]; then
    echo "Error: worktree directory does not exist: $worktree_dir"
    return 1
  fi

  git worktree add "$worktree_path" -b "$branch_name" || return 1

  local abs_worktree_path
  abs_worktree_path=$(cd "$worktree_path" && pwd)

  echo "Worktree created at: $abs_worktree_path"

  cd "$abs_worktree_path" || return 1
  claude --name "$branch_name"
}

# If script is executed directly (not sourced), run the function
if [[ "$ZSH_EVAL_CONTEXT" != *:file* ]]; then
  new-gwt-claude "$@"
fi
